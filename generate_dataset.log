  [dialog 5/8]   |       "description": "A scrumptious potato patty topped with a delectable Italian herb sauce and shredded onions placed between perfectly toasted buns.",
  [dialog 5/8]   |       "sodium": 504.19,
  [dialog 5/8]   |       "tag": "A surprise that will leave you wide-eyed.",
  [dialog 5/8]   |       "ingredients": "Regular Bun, Italian mayo, Shredded onion, Herb Chilli Potato patty",
  [dialog 5/8]   |       "added_sugar": 1.64,
  [dialog 5/8]   |       "allergens": [
  [dialog 5/8]   |         "Cereal containing gluten",
