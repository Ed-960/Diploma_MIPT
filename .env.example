API_MODEL=grok-3-mini
API_PROVIDER=openai
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DEVICE=auto
HF_TOKEN=
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.x.ai/v1
# OpenRouter (https://openrouter.ai/api/v1): при 403 «Venice.ai is at capacity» код по умолчанию
# шлёт provider.ignore=[venice]. Отключить: OPENROUTER_PROVIDER_IGNORE=none
# OPENROUTER_PROVIDER_IGNORE=venice,deepinfra
RAG_MAX_PROMPT_LINES=15
# 1 = mini-LLM отдаёт JSON (search_query + excluded_allergens + kcal); 0 = старый rewrite + regex
RAG_JSON_REWRITE=1
RAG_MODE=vector
RAG_SOFT_DISTANCE_MAX=1.15
REWRITE_MODEL=grok-3-mini
